{
  "compilerOptions": {
    "experimentalDecorators": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "target": "es2017",
    "declaration": true,
    "lib": ["es2017", "dom"],
    "types": ["node"],
    "outDir": "lib/cjs"
  },
  "include": ["src/", "examples/"],
  "exclude": ["node_modules"]
}
